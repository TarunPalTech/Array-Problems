/* Right rotate array by k positions */

void reverse(int a[], int start, int end){
    while(start<end){
        int temp = a[start];
        a[start] = a[end];
        a[end] = temp;
        start++;
        end--;
    }
}

void rightArrayRotation(int a[], int size, int k){
    k = k % size;
    
    reverse(a, size - k, size - 1); // Step - 1
    reverse(a, 0, size - k - 1);  // Step - 2
    reverse(a, 0, size - 1); // Step - 3
}
